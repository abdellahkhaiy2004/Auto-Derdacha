# ──────────────────────────────────────────────────────────────────────────────
# Auto-Derdacha — environment variables template
# Copy this file to .env (in the same directory) and fill in the values.
# .env is git-ignored and must NEVER be committed.
# Run with: flutter run --dart-define-from-file=.env
# ──────────────────────────────────────────────────────────────────────────────

# Groq API key.
# How to obtain: sign up (free) at https://console.groq.com, open
# Dashboard → API Keys → Create API key, copy the generated key.
GROQ_API_KEY=

# Base URL for Groq's OpenAI-compatible API.
# Leave at the default unless you are self-hosting or using a mirror.
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Whisper model used for speech-to-text transcription.
# Current options: https://console.groq.com/docs/models (audio section).
# Recommended: whisper-large-v3 (best multilingual accuracy, free tier).
GROQ_STT_MODEL=whisper-large-v3

# LLM model used for meeting summarization.
# Current options: https://console.groq.com/docs/models (text section).
# Recommended: llama-3.3-70b-versatile (long context, free tier).
GROQ_LLM_MODEL=llama-3.3-70b-versatile
